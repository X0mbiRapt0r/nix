#!/usr/bin/env bash
set -euo pipefail

program_name="${0##*/}"

usage() {
  cat <<USAGE
Usage:
  $program_name [--repo PATH] [--message MESSAGE] [--no-push] [--print-command]

Fast-forward the current branch, update and validate this repo's flake inputs,
commit flake.lock if it changed, and push. The repo must be on a branch and
clean before updating so this helper never creates an unreachable commit or
commits unrelated work by accident.

Options:
  --repo PATH         Override the default repo path for this OS.
  --message MESSAGE  Commit message to use when flake.lock changes.
  --no-push          Commit but do not push.
  --print-command    Print the commands without running them.
  -h, --help         Show this help.
USAGE
}

repo_dir=""
commit_message="update flake inputs"
push=true
print_command=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      repo_dir="${2:?Missing value for --repo}"
      shift 2
      ;;
    --message)
      commit_message="${2:?Missing value for --message}"
      shift 2
      ;;
    --no-push)
      push=false
      shift
      ;;
    --print-command)
      print_command=true
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
  echo "Run $program_name as your normal user; it modifies the Git checkout." >&2
  exit 1
fi

case "$(uname -s)" in
  Darwin)
    repo_dir="${repo_dir:-$HOME/Library/Mobile Documents/com~apple~CloudDocs/Documents/github.com/X0mbiRapt0r/nix}"
    ;;
  Linux)
    repo_dir="${repo_dir:-$HOME/Documents/github.com/X0mbiRapt0r/nix}"
    ;;
  *)
    echo "Unsupported OS: $(uname -s)" >&2
    exit 1
    ;;
esac

if [[ ! -d "$repo_dir" ]]; then
  echo "Repo path does not exist: $repo_dir" >&2
  echo "Re-run with --repo PATH if this machine uses a different checkout path." >&2
  exit 1
fi

if [[ ! -f "$repo_dir/flake.nix" ]]; then
  echo "Repo path does not look like the nix flake repo: $repo_dir" >&2
  exit 1
fi

run() {
  printf '+'
  printf ' %q' "$@"
  printf '\n'

  if [[ "$print_command" != true ]]; then
    "$@"
  fi
}

require_clean_worktree() {
  local status

  # Updating is an explicit maintenance action. Leave any existing work for
  # Irish to classify instead of folding it into a generated lockfile commit.
  status="$(git status --porcelain=v1)"

  if [[ -n "$status" ]]; then
    cat >&2 <<EOF
Refusing to update flake.lock because the repo has uncommitted changes.
Commit, stash, or remove these first, then re-run $program_name:

$status
EOF
    exit 1
  fi
}

require_branch() {
  branch="$(git branch --show-current)"

  if [[ -z "$branch" ]]; then
    echo "Refusing to update flake.lock from detached HEAD. Check out a branch first." >&2
    exit 1
  fi
}

validation_failed() {
  cat >&2 <<EOF
Flake validation failed. flake.lock remains modified for inspection, but it
was not staged, committed, or pushed.
EOF
  exit 1
}

printf 'Repo: %s\n' "$repo_dir"

if [[ "$print_command" == true ]]; then
  run cd "$repo_dir"
  run git status --porcelain=v1
  run git branch --show-current
  run git pull --ff-only origin CURRENT_BRANCH
  run nix flake update
  run nix flake check --no-build --all-systems --no-write-lock-file
  run nix flake check --no-write-lock-file
  run git add flake.lock
  run git commit -m "$commit_message"
  if [[ "$push" == true ]]; then
    run git push origin CURRENT_BRANCH
  fi
  exit 0
fi

cd "$repo_dir"
require_clean_worktree
require_branch
run git pull --ff-only origin "$branch"
run nix flake update

if ! run nix flake check --no-build --all-systems --no-write-lock-file; then
  validation_failed
fi

if ! run nix flake check --no-write-lock-file; then
  validation_failed
fi

run git add flake.lock

if git diff --cached --quiet -- flake.lock; then
  echo "No flake.lock changes to commit."
  exit 0
fi

run git commit -m "$commit_message"

if [[ "$push" == true ]]; then
  run git push origin "$branch"
fi
