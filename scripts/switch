#!/usr/bin/env bash
set -euo pipefail

program_name="${0##*/}"

usage() {
  cat <<USAGE
Usage:
  $program_name [HOST] [--repo PATH] [--pull|--no-pull] [--print-command] [-- EXTRA_ARGS...]
  $program_name --host HOST [--repo PATH] [--pull|--no-pull] [--print-command] [-- EXTRA_ARGS...]

Build and activate the Nix flake for the current machine.

Options:
  --host HOST       Override the detected flake host name.
  --repo PATH       Override the default repo path for this OS.
  --pull            Run git pull --ff-only from a clean checkout before switching.
  --no-pull         Skip the pre-switch git pull.
  --print-command   Print the planned commands without running them.
  -h, --help        Show this help.

Any arguments after -- are passed through to darwin-rebuild or nixos-rebuild.
USAGE
}

host=""
repo_dir=""
pull_before_switch=""
print_command=false
extra_args=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      host="${2:?Missing value for --host}"
      shift 2
      ;;
    --repo)
      repo_dir="${2:?Missing value for --repo}"
      shift 2
      ;;
    --pull)
      pull_before_switch=true
      shift
      ;;
    --no-pull)
      pull_before_switch=false
      shift
      ;;
    --print-command)
      print_command=true
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    --)
      shift
      extra_args+=("$@")
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      if [[ -z "$host" ]]; then
        host="$1"
        shift
      else
        echo "Unknown argument: $1" >&2
        usage >&2
        exit 2
      fi
      ;;
  esac
done

detect_host() {
  if [[ "$(uname -s)" == "Darwin" ]] && command -v scutil >/dev/null 2>&1; then
    scutil --get LocalHostName 2>/dev/null && return 0
  fi

  hostname -s
}

os="$(uname -s)"
detected_host="$(detect_host)"

root_cmd=()
if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
  root_cmd=(sudo)
fi

case "$os" in
  Darwin)
    repo_dir="${repo_dir:-$HOME/Library/Mobile Documents/com~apple~CloudDocs/Documents/github.com/X0mbiRapt0r/nix}"
    host="${host:-$detected_host}"
    pull_before_switch="${pull_before_switch:-false}"
    rebuild_cmd=("${root_cmd[@]}" darwin-rebuild switch)
    ;;
  Linux)
    repo_dir="${repo_dir:-$HOME/Documents/github.com/X0mbiRapt0r/nix}"
    host="${host:-$detected_host}"
    if [[ -z "$pull_before_switch" ]]; then
      # XR-PC is expected to follow the shared checkout before each rebuild.
      # Other Linux hosts opt in explicitly so future hosts are not surprised.
      if [[ "$host" == "XR-PC" ]]; then
        pull_before_switch=true
      else
        pull_before_switch=false
      fi
    fi
    rebuild_cmd=("${root_cmd[@]}" nixos-rebuild switch)
    ;;
  *)
    echo "Unsupported OS: $os" >&2
    exit 1
    ;;
esac

if [[ -z "$host" ]]; then
  echo "Could not detect a host name. Re-run with --host HOST." >&2
  exit 1
fi

if [[ ! -d "$repo_dir" ]]; then
  echo "Repo path does not exist: $repo_dir" >&2
  echo "Re-run with --repo PATH if this machine uses a different checkout path." >&2
  exit 1
fi

if [[ ! -f "$repo_dir/flake.nix" ]]; then
  echo "Repo path does not look like the nix flake repo: $repo_dir" >&2
  exit 1
fi

flake_ref="$repo_dir#$host"
cmd=("${rebuild_cmd[@]}" --flake "$flake_ref" -L "${extra_args[@]}")

printf 'Host: %s\n' "$host"
printf 'Repo: %s\n' "$repo_dir"
printf 'Pull: %s\n' "$pull_before_switch"

if [[ "$pull_before_switch" == true ]]; then
  status_cmd=(git -C "$repo_dir" status --porcelain=v1)
  pull_cmd=(git -C "$repo_dir" pull --ff-only)
  printf 'Pre-switch check:'
  printf ' %q' "${status_cmd[@]}"
  printf '\n'
  printf 'Pre-switch command:'
  printf ' %q' "${pull_cmd[@]}"
  printf '\n'
fi

printf 'Command:'
printf ' %q' "${cmd[@]}"
printf '\n'

if [[ "$print_command" == true ]]; then
  exit 0
fi

if [[ "$pull_before_switch" == true ]]; then
  if ! worktree_status="$("${status_cmd[@]}")"; then
    echo "Cannot inspect Git checkout: $repo_dir" >&2
    exit 1
  fi

  if [[ -n "$worktree_status" ]]; then
    cat >&2 <<EOF
Refusing to pull because the repo has uncommitted changes:

$worktree_status
EOF
    exit 1
  fi

  if ! "${pull_cmd[@]}"; then
    cat >&2 <<EOF

Git pull failed. If the error mentions .git/FETCH_HEAD permission denied,
fix the XR-PC checkout ownership once with:

  sudo chown -R "\$(id -un):\$(id -gn)" "$repo_dir"

Then re-run $program_name.
EOF
    exit 1
  fi
fi

"${cmd[@]}"
